PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change_this_secret

# Local (o variables sueltas). En Railway suele usarse DATABASE_URL / MYSQL_URL del plugin MySQL.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=carpinteria
# Forzar SSL (opcional). En producción con host remoto se activa solo si no es localhost.
# DB_SSL=true

# DATABASE_URL=mysql://user:pass@host:3306/dbname
# MYSQL_URL=mysql://...
# MYSQLHOST= MYSQLPORT= MYSQLUSER= MYSQLPASSWORD= MYSQLDATABASE=

# Carpeta de subidas (en Railway: montar Volume en esta ruta, ej. /data/uploads)
UPLOAD_DIR=./uploads
# URL pública del backend sin barra final (para que el admin guarde URLs absolutas de imágenes)
# PUBLIC_BASE_URL=https://tu-api.up.railway.app

# Login admin: por defecto desde tabla admin_users en MySQL (ver schema.sql / migrations/003).
# Si no hay ningún usuario en admin_users, se usan estas variables como respaldo:
ADMIN_EMAIL=mattiuccimicaelammm@gmail.com
# ADMIN_PASSWORD=...  # respaldo solo si no existe tabla admin_users (Railway: variable opcional)
ADMIN_PASSWORD_HASH=
# Generar hash para actualizar MySQL: npm run hash-password -- "nueva_clave"
