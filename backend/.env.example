PORT=4000
# En Railway conviene NODE_ENV=production (también detectamos RAILWAY_ENVIRONMENT para SSL a MySQL).
NODE_ENV=development
# Orígenes permitidos separados por coma, o * para reflejar el Origin del cliente (útil con credenciales).
CORS_ORIGIN=http://localhost:5173
# Sin espacios al final; si cambiás el secret, los JWT viejos dejan de valer.
JWT_SECRET=change_this_secret

# Local (o variables sueltas). En Railway suele usarse DATABASE_URL / MYSQL_URL del plugin MySQL.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=carpinteria
# SSL a MySQL: en Railway se activa solo con host no local (también si existe RAILWAY_ENVIRONMENT).
# Forzar off (p. ej. túnel local a MySQL): DB_SSL=false
# DB_SSL=true

# DATABASE_URL=mysql://user:pass@host:3306/dbname
# MYSQL_URL=mysql://...
# MYSQLHOST= MYSQLPORT= MYSQLUSER= MYSQLPASSWORD= MYSQLDATABASE=

# Carpeta de subidas (en Railway: montar Volume en esta ruta, ej. /data/uploads)
UPLOAD_DIR=./uploads
# URL pública del backend sin barra final (imágenes + webhook Mercado Pago: .../api/webhook)
# PUBLIC_BASE_URL=https://tu-api.up.railway.app
# URL pública del sitio Vue (back_urls success/failure/pending). En Railway es obligatorio (MP rechaza localhost).
# Si no está definido pero CORS_ORIGIN es una URL https concreta, el backend la usa como fallback.
# PUBLIC_FRONTEND_URL=https://tu-front.up.railway.app
# Token de producción o test (NUNCA en el frontend)
# MERCADOPAGO_ACCESS_TOKEN=
# Envío a domicilio: respaldo si falla la tabla app_settings (migración 009). El valor en producción lo define el admin en Ajustes.
# SHIPPING_DELIVERY_PRICE_ARS=8000
# Webhook: por defecto NO se envía notification_url en la preferencia (MP usa la URL del panel Webhooks).
# Solo si necesitás forzarla: MERCADOPAGO_SEND_NOTIFICATION_URL=true
# O URL explícita: MERCADOPAGO_NOTIFICATION_URL=https://tu-api.up.railway.app/api/webhook

# Login admin: por defecto desde tabla admin_users en MySQL (ver schema.sql / migrations/003).
# Si no hay ningún usuario en admin_users, se usan estas variables como respaldo:
ADMIN_EMAIL=mattiuccimicaelammm@gmail.com
# ADMIN_PASSWORD=...  # respaldo solo si no existe tabla admin_users (Railway: variable opcional)
ADMIN_PASSWORD_HASH=
# Generar hash para actualizar MySQL: npm run hash-password -- "nueva_clave"
